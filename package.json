{
  "name": "elm-design-tokens",
  "private": true,
  "type": "module",
  "scripts": {
    "make:docs": "elm make --docs=docs.json",
    "test": "elm-test",
    "format": "elm-format --yes src/ tests/",
    "format:check": "elm-format src/ tests/ --validate",
    "lint": "elm-review",
    "postinstall": "elm-tooling install"
  },
  "devDependencies": {
    "elm-review": "^2.13.5",
    "elm-test": "^0.19.1-revision17",
    "elm-tooling": "^1.17.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  }
}
