{
    "type": "package",
    "name": "mpizenberg/elm-design-tokens",
    "summary": "DTCG Design Tokens types, JSON codecs, and CSS helpers",
    "license": "BSD-3-Clause",
    "version": "1.0.0",
    "exposed-modules": [
        "DesignTokens.Color",
        "DesignTokens.Dimension",
        "DesignTokens.FontFamily",
        "DesignTokens.FontWeight",
        "DesignTokens.Duration",
        "DesignTokens.CubicBezier",
        "DesignTokens.Shadow",
        "DesignTokens.Border",
        "DesignTokens.StrokeStyle",
        "DesignTokens.Gradient",
        "DesignTokens.Typography",
        "DesignTokens.Transition"
    ],
    "elm-version": "0.19.1 <= v < 0.20.0",
    "dependencies": {
        "elm/core": "1.0.5 <= v < 2.0.0",
        "elm/json": "1.1.3 <= v < 2.0.0"
    },
    "test-dependencies": {
        "elm-explorations/test": "2.0.0 <= v < 3.0.0"
    }
}
