{
  "colors": {
    "$type": "color",
    "primary": {
      "$value": { "colorSpace": "srgb", "components": [0.2, 0.4, 0.8] }
    },
    "secondary": {
      "$value": "{colors.primary}"
    }
  },
  "spacing": {
    "$type": "dimension",
    "small": { "$value": { "value": 8, "unit": "px" } },
    "medium": { "$value": { "value": 16, "unit": "px" } }
  },
  "ratio": {
    "$type": "number",
    "$value": 1.5
  },
  "label": {
    "$type": "string",
    "$value": "hello"
  },
  "enabled": {
    "$type": "boolean",
    "$value": true
  }
}
